# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # the Twilio number you purchased; this is the "caller" number you report in the submission form

# The number under test (do not change)
TARGET_NUMBER=+18054398008

# OpenAI Realtime API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_REALTIME_MODEL=gpt-realtime

# Public base URL for this server, e.g. your ngrok https URL (no trailing slash)
# Twilio needs this to reach your local webhook/websocket server.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
